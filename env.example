# Example environment file for config-service
# Copy this file to .env and fill in your actual secrets

# Database Configuration
DB_PASSWORD=replace_with_database_password

# Redis Configuration  
REDIS_PASSWORD=

# Exchange API Keys
EXCHANGE_BINANCE_API_KEY=your_binance_api_key_here
EXCHANGE_BINANCE_API_SECRET=your_binance_api_secret_here
EXCHANGE_BYBIT_API_KEY=your_bybit_api_key_here
EXCHANGE_BYBIT_API_SECRET=your_bybit_api_secret_here
EXCHANGE_CRYPTOCOM_API_KEY=your_cryptocom_api_key_here
EXCHANGE_CRYPTOCOM_API_SECRET=your_cryptocom_api_secret_here

# Testing Mode (set to 1 for development/testing)
TESTING=0 

# MCP Configuration
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Dashboard UI rollout
# legacy = existing dashboard at /
# portfolio = new portfolio intelligence dashboard at /
DASHBOARD_UI_VERSION=legacy

# External token/news data
NEWS_ENABLED=true
COINSTATS_ENABLED=false
COINSTATS_API_KEY=your_coinstats_api_key_here
COINSTATS_MONTHLY_CREDIT_LIMIT=20000
COINSTATS_RATE_LIMIT_PER_SECOND=2
COINSTATS_HARD_BUDGET_PERCENT=95
